# Cloudflare Pages _headers
# IMPORTANT: Do NOT set Content-Type manually — Cloudflare Pages auto-detects
# MIME types correctly from file extensions. Setting them manually causes conflicts.

# Root HTML: never cache so new deploys propagate immediately
/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

# Service Worker: must never be cached so updates reach users
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# Manifest: short cache is OK
/manifest.json
  Cache-Control: public, max-age=86400

# Hashed Vite assets: safe to cache forever (content-addressed file names)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Security headers applied to every response
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(self), camera=(self), microphone=()
