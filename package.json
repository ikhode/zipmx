{
  "name": "zipp",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:vite\" \"npm:cf-dev\"",
    "cf-dev": "wrangler pages dev --compatibility-flags=nodejs_compat --d1=DB --port 8788 --proxy 5173",
    "vite": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "deploy": "npm run build && wrangler d1 migrations apply zipp_database --remote && wrangler pages deploy dist --project-name zipp --branch produccion"

  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@libsql/client": "^0.17.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.10",
    "leaflet": "^1.9.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260403.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.8",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.0.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "vitest": "^4.1.2",
    "wrangler": "^4.80.0"
  }
}
